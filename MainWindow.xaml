<Window x:Class="AmongUsLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Among Us Launcher"
        Height="560" Width="660"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        MinHeight="450" MinWidth="520">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Among Us Launcher" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource AccentPrimaryBrush}"/>
        </StackPanel>

        <!-- Status Card -->
        <Border Grid.Row="1" Background="{StaticResource BgSurfaceBrush}"
                CornerRadius="12" Padding="16" Margin="0,0,0,14"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
            <TextBlock x:Name="StatusText" Text="Ready to download" FontSize="14"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
            <Button x:Name="DownloadButton" Content="&#x2B07; Download"
                    Style="{StaticResource ActionButton}"
                    Background="{StaticResource AccentPrimaryBrush}"
                    Margin="0,0,14,0"
                    Click="DownloadButton_Click"/>
            <Button x:Name="PlayButton" Content="&#x25B6; Play"
                    Style="{StaticResource ActionButton}"
                    Background="{StaticResource AccentGreenBrush}"
                    IsEnabled="False"
                    Click="PlayButton_Click"/>
        </StackPanel>

        <!-- Progress -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="3"
                     Height="6" Margin="0,0,0,14"
                     Foreground="{StaticResource AccentPrimaryBrush}"
                     Background="{StaticResource BgSurfaceBrush}"
                     BorderThickness="0"
                     Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed"/>

        <!-- Log Panel -->
        <Border Grid.Row="4" Background="{StaticResource BgSurfaceBrush}"
                CornerRadius="12" Padding="12"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="LogList" Background="Transparent" BorderThickness="0"
                              Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}"
                                       Foreground="{Binding Color}"
                                       TextWrapping="Wrap"
                                       Margin="0,2"
                                       FontSize="13"
                                       FontFamily="Consolas"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
